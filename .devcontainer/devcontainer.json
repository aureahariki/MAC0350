{
"name": "Meu-Projeto",
"image": "mcr.microsoft.com/devcontainers/universal:latest",
"features": {
    "ghcr.io/devcontainers/features/git-lfs:1": {}
},
"forwardPorts": [8000],
"postCreateCommand": "pip install -r requirements.txt && python manage.py migrate",
"customizations": {
    "vscode": {
        "extensions": [
            "ms-python.python",
            "bat67.django-html"
            ]
        }
    }
}